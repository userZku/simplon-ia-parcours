# === COPIE CE FICHIER EN `.env` AVANT DE LANCER LA STACK ===
# Commande : cp .env.example .env
# Sans .env, `docker compose up` plante avec "env file not found".

# --- Modèle HF Transformers ---
# Modèle par défaut (français, 5 étoiles -> à mapper en 3 classes)
MODEL_NAME_HF=cmarkea/distilcamembert-base-sentiment

# --- Validation Pydantic ---
MAX_TEXT_LENGTH=2000
